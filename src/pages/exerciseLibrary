// One card in the 14-day plan grid
function PlanDayCard({ day, isRest, picks, isDay14, onDay14Click, intensityBoostCount }) {
  function getBoostedRange(rangeString) {
    if (intensityBoostCount === 0) return rangeString;
    const parts = rangeString.split("–");
    if (parts.length !== 2) return rangeString;
    const mult = Math.pow(1.15, intensityBoostCount);
    return Math.round(parseInt(parts[0]) * mult) + "–" + Math.round(parseInt(parts[1]) * mult);
  }

  return (
    <div
      className="rounded-xl p-3 transition-all duration-200"
      style={{
        background:   "#0D0D0D",
        border:       isDay14 ? "1px solid #C6F135" : "1px solid #1E1E1E",
        cursor:       isDay14 ? "pointer" : "default",
        transform:    "translateY(0)",
      }}
      onClick={isDay14 ? onDay14Click : undefined}
      onMouseEnter={e => { e.currentTarget.style.transform = "translateY(-4px)"; }}
      onMouseLeave={e => { e.currentTarget.style.transform = "translateY(0)"; }}
    >
      {/* Day number */}
      <p style={{ fontFamily: "'Barlow Condensed',sans-serif", fontWeight: 900, fontSize: "30px", lineHeight: 1, color: "#2A2A2A", marginBottom: "8px" }}>
        {String(day).padStart(2, "0")}
      </p>

      {isRest ? (
        <p style={{ fontSize: "9px", fontWeight: 700, letterSpacing: "0.1em", textTransform: "uppercase", color: "#333333" }}>
          Rest Day
        </p>
      ) : (
        picks.map((ex) => (
          <div key={ex.id} style={{ marginBottom: "4px" }}>
            <div style={{ display: "flex", alignItems: "center", gap: "5px", marginBottom: "2px" }}>
              <span style={{ display: "inline-block", width: "7px", height: "7px", borderRadius: "50%", flexShrink: 0, background: getCatColor(ex.category) }} />
              <Link
                to={ex.link}
                onClick={e => e.stopPropagation()}
                style={{ fontSize: "11px", fontWeight: 700, color: "#00E5FF", textDecoration: "none", overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}
                onMouseEnter={e => e.target.style.color = "#C6F135"}
                onMouseLeave={e => e.target.style.color = "#00E5FF"}
              >
                {ex.name}
              </Link>
            </div>
            <p style={{ fontSize: "9px", color: intensityBoostCount > 0 ? "#FFAA00" : "#555555", marginLeft: "11px" }}>
              {getBoostedRange(ex.kcalRange)} kcal/10min
            </p>
          </div>
        ))
      )}

      {isDay14 && (
        <p style={{ fontSize: "9px", fontWeight: 700, letterSpacing: "0.1em", textTransform: "uppercase", color: "#C6F135", marginTop: "8px" }}>
          Tap to Finish
        </p>
      )}
    </div>
  );
}

