export default function ExerciseLibrary() {
  // ── State ──────────────────────────────────────────────────
  const [search,        setSearch]        = useState("");
  const [filterCat,     setFilterCat]     = useState("All");
  const [filterDiff,    setFilterDiff]    = useState("All");
  const [userLevel,     setUserLevel]     = useState(mockUser.level);
  const [boostCount,    setBoostCount]    = useState(0);
  const [logOpen,       setLogOpen]       = useState(false);
  const [planOpen,      setPlanOpen]      = useState(false);
  const [todayKcal,     setTodayKcal]     = useState(0);
  const [toastMsg,      setToastMsg]      = useState(null);

  // Build plan days once and store them (so they don't re-randomise on every render)
  const planDaysRef = useRef(null);
  if (!planDaysRef.current) {
    planDaysRef.current = buildPlanDays(userLevel);
  }

  // When level changes rebuild the plan
  useEffect(() => {
    planDaysRef.current = buildPlanDays(userLevel);
  }, [userLevel, boostCount]);

  // ── Helpers ────────────────────────────────────────────────
  function buildPlanDays(level) {
const pool = getMatchingExercises(mockUser.goal, level, mockUser.weightGoal, mockUser.limitations);
    const lastUsed = {};
    const days     = [];
    for (let day = 1; day <= 14; day++) {
      const isRest = (day % 4 === 0) && day !== 14;
      const count  = (day % 3 === 0) ? 3 : 2;
      let picks    = [];
      if (!isRest) {
        const available = pool.filter(ex => !lastUsed[ex.id] || (day - lastUsed[ex.id]) >= 3);
        const source    = available.length >= count ? available : pool;
        picks           = pickRandom(source, count);
        picks.forEach(ex => { lastUsed[ex.id] = day; });
      }
      days.push({ day, isRest, picks });
    }
    return days;
  }

  function showToast(text, color = "#C6F135") {
    setToastMsg({ text, color });
    setTimeout(() => setToastMsg(null), 3500);
  }

  function handleLogSave(burned, name) {
    setLogOpen(false);
    setTodayKcal(getTodayCalories());
    showToast(`${name} logged · ${burned} kcal burned`);
  }

  function handlePlanContinue() {
    const levels = ["beginner", "intermediate", "advanced"];
    const idx    = levels.indexOf(userLevel);
    if (boostCount < 3) {
      const next = boostCount + 1;
      setBoostCount(next);
      const pct = Math.round((Math.pow(1.15, next) - 1) * 100);
      showToast(`Reps +${pct}% · Level stays ${userLevel}`);
    } else if (idx < levels.length - 1) {
      setUserLevel(levels[idx + 1]);
      setBoostCount(0);
      showToast(`Level advanced to ${levels[idx + 1].toUpperCase()}`, "#00E5FF");
    } else {
      const next = boostCount + 1;
      setBoostCount(next);
      const pct = Math.round((Math.pow(1.15, next) - 1) * 100);
      showToast(`Already Advanced · Reps +${pct}%`, "#FF2A5E");
    }
    setPlanOpen(false);
  }

  // ── Filtered exercises ─────────────────────────────────────
  const filtered = exercises.filter(ex =>
